# ============================================
# FoodRank 环境变量配置
# 复制这个文件，改名为 .env，然后填入你的值
# ============================================

# Google Places API Key (必须)
# 如何获取：https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# SerpAPI Key — 用来搜索小红书帖子 (小红书功能必须)
# 免费注册：https://serpapi.com/  (每月 100 次免费搜索)
# 注册后在 Dashboard → API Key 复制
SERPAPI_KEY=your_serpapi_key_here

# Google Custom Search Engine ID — 已废弃，留着不影响
# GOOGLE_SEARCH_ENGINE_ID=your_cse_id_here

# 服务器端口 (可选，默认 3000)
PORT=3000
